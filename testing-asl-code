import tensorflow as tf
import numpy as np
from PIL import Image
import os
from sklearn.metrics import f1_score, classification_report

MODEL_PATH = 'best_model.keras'
TEST_PATH  = 'ASL Secret Test Data'
LABELS     = ['A', 'B', 'C', 'D', 'E']

model = tf.keras.models.load_model(MODEL_PATH)
print("Model loaded successfully.")

def preprocess_image(img_path):
    img = Image.open(img_path).convert('RGB')
    img = img.resize((224, 224))
    img_array = np.array(img, dtype=np.float32)
    img_array = (img_array / 127.5) - 1.0
    return img_array

def evaluate_subfolders(test_path):
    y_true, y_pred = [], []
    for true_label in sorted(os.listdir(test_path)):
        folder = os.path.join(test_path, true_label)
        if not os.path.isdir(folder):
            continue
        for fname in os.listdir(folder):
            if not fname.lower().endswith(('.jpg','.jpeg','.png')):
                continue
            img = preprocess_image(os.path.join(folder, fname))
            img = np.expand_dims(img, 0)
            pred_idx  = np.argmax(model.predict(img, verbose=0))
            predicted = LABELS[pred_idx]
            y_true.append(true_label)
            y_pred.append(predicted)
    correct = sum(t==p for t,p in zip(y_true, y_pred))
    print(f"\nTest Accuracy : {correct/len(y_true):.4f}  ({correct}/{len(y_true)})")
    print(f"Macro F1 Score: {f1_score(y_true, y_pred, average='macro'):.4f}")
    print("\nClassification Report:")
    print(classification_report(y_true, y_pred, target_names=LABELS))

evaluate_subfolders(TEST_PATH)
